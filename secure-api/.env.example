# HTTP
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Gmail SMTP (use an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM_NAME="USMBA Dashboard"

# Fixed recipients
PRESIDENT_EMAIL=president@gmail.com
SERVICE_EMAIL=service@gmail.com

# Database (reuses Laravel DB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=flsh_stats
DB_USER=root
DB_PASS=

# Password reset
RESET_CODE_TTL_MINUTES=10
BCRYPT_ROUNDS=12
RESET_MAX_ATTEMPTS_PER_HOUR=5

# Logging
LOG_LEVEL=info
